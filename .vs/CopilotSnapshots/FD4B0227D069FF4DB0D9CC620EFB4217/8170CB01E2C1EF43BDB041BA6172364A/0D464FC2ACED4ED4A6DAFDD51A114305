            {
                bool ok = _compressorService?.RestoreOriginalFile() ?? false;
                MessageBox.Show(ok ? "Original restored." : "Restore failed or no backup.", "Restore", MessageBoxButtons.OK, MessageBoxIcon.Information);
            }
            catch (Exception ex)
            {
                MessageBox.Show("Restore failed: " + ex.Message, "Restore", MessageBoxButtons.OK, MessageBoxIcon.Error);
            }
        }
    }
}
    

